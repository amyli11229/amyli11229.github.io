---
layout: layouts/base.njk
---
<main class="contact-page">
    <div class="contact-page-inner">
        <a href="index.html" class="project-detail-back">← Home</a>

        <header class="contact-page-header">
            <h1>{{ heading }}</h1>
            <p class="contact-page-lead">{{ lead }}</p>
        </header>

        <div class="contact-page-links" aria-label="Contact links">
            <a href="mailto:{{ site.email }}" class="contact-link">{{ site.email }}</a>
            <a href="{{ site.linkedin }}" class="contact-link" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            <a href="{{ site.github }}" class="contact-link" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>

        <div class="contact-options">
            <section class="contact-option" aria-labelledby="contact-board-heading">
                <h2 id="contact-board-heading">{{ form_heading }}</h2>
                <p class="contact-option-desc">{{ form_desc }}</p>

                <div class="contact-form-embed">
                    <iframe src="{{ site.contact_form_embed }}" title="Contact form" width="" height="" frameborder="0" marginheight="0" marginwidth="0">Loading…</iframe>
                </div>

                <p class="contact-form-fallback">
                    <a href="{{ site.contact_form_url }}" class="contact-link" target="_blank" rel="noopener noreferrer">Open form in a new tab</a>
                </p>
            </section>
        </div>
    </div>
</main>
